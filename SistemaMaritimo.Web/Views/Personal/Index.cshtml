@model List<SistemaMaritimo.Web.Models.PersonalViewModel>

@{
    ViewData["Title"] = "Personal";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Tripulación y Personal</h2>
    <a asp-action="Create" class="btn btn-primary">Nuevo registro</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-bordered table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Identificación</th>
                    <th>Rol primario</th>
                    <th>Fecha contratación</th>
                    <th>Estado</th>
                    <th style="width:220px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.NombreCompleto</td>
                            <td>@item.IdentificacionUnica</td>
                            <td>@item.RolPrimario</td>
                            <td>@item.FechaContratacion.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (item.Activo)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">Detalle</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                                @if (item.Activo)
                                {
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('¿Desea desactivar este registro?');">
                                        Desactivar
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center">No hay registros.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>