@model SistemaMaritimo.Web.Models.AsignacionTripulacionViewModel

@{
    ViewData["Title"] = "Asignar a Barco";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0">Asignar a Barco</h4>
            </div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="CrearAsignacion" method="post">
                    <input asp-for="PersonalId" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="BarcoId" class="form-label">Barco</label>
                        <select asp-for="BarcoId" class="form-select" asp-items="ViewBag.Barcos">
                            <option value="">-- Seleccione un barco --</option>
                        </select>
                        <span asp-validation-for="BarcoId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PuestoAsignado" class="form-label"></label>
                        <input asp-for="PuestoAsignado" class="form-control" />
                        <span asp-validation-for="PuestoAsignado" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FechaInicio" class="form-label"></label>
                        <input asp-for="FechaInicio" class="form-control" />
                        <span asp-validation-for="FechaInicio" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Detalle" asp-route-id="@Model.PersonalId" class="btn btn-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-success">Guardar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>