@using Newtonsoft.Json.Linq

@{
    var rolesJson = Context.Session.GetString("Roles");

    bool esAdministrador = false;
    bool esCapitan = false;
    bool esPrimerOficial = false;
    bool esIngeniero = false;
    bool esMarinero = false;
    bool esPersonalBase = false;

    if (!string.IsNullOrWhiteSpace(rolesJson))
    {
        try
        {
            var roles = JArray.Parse(rolesJson).Select(r => r.ToString()).ToList();

            esAdministrador = roles.Any(r => r.Equals("Administrador", StringComparison.OrdinalIgnoreCase));
            esCapitan = roles.Any(r => r.Equals("Capitan", StringComparison.OrdinalIgnoreCase));
            esPrimerOficial = roles.Any(r => r.Equals("PrimerOficial", StringComparison.OrdinalIgnoreCase));
            esIngeniero = roles.Any(r => r.Equals("IngenieroJefe", StringComparison.OrdinalIgnoreCase));
            esMarinero = roles.Any(r => r.Equals("Marinero", StringComparison.OrdinalIgnoreCase));
            esPersonalBase = roles.Any(r => r.Equals("PersonalBase", StringComparison.OrdinalIgnoreCase));
        }
        catch
        {
            esAdministrador = false;
            esCapitan = false;
            esPrimerOficial = false;
            esIngeniero = false;
            esMarinero = false;
            esPersonalBase = false;
        }
    }
}


<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema Marítimo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Dashboard" asp-action="Index">Sistema Marítimo</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menuNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                    @if (esAdministrador)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Usuarios" asp-action="Index">Usuarios</a>
                        </li>
                    }
                    @if (esAdministrador || esCapitan || esPrimerOficial || esIngeniero)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Personal" asp-action="Index">Personal</a>
                        </li>
                    }
                    @if (esAdministrador || esCapitan || esPrimerOficial || esIngeniero)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Barcos" asp-action="Index">Barcos</a>
                        </li>
                    }
                    @if (esAdministrador || esCapitan || esPrimerOficial)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Travesias" asp-action="Index">Travesías</a>
                        </li>
                    }
                    @if (esAdministrador || esIngeniero || esPersonalBase)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="OrdenesServicio" asp-action="Index">Órdenes</a>
                        </li>
                    }
                </ul>

                <span class="navbar-text text-white me-3">
                    @Context.Session.GetString("NombreUsuario")
                </span>

                <a class="btn btn-outline-light btn-sm" asp-controller="Auth" asp-action="Logout">Cerrar sesión</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>