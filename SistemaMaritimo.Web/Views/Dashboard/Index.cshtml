@model SistemaMaritimo.Web.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">Dashboard General</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-4 border-primary">
            <div class="card-body">
                <h6 class="text-muted">Barcos activos</h6>
                <h2>@Model.Resumen.BarcosActivos</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-4 border-secondary">
            <div class="card-body">
                <h6 class="text-muted">Barcos archivados</h6>
                <h2>@Model.Resumen.BarcosArchivados</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-4 border-info">
            <div class="card-body">
                <h6 class="text-muted">Travesías planeadas</h6>
                <h2>@Model.Resumen.TravesiasPlaneadas</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-4 border-warning">
            <div class="card-body">
                <h6 class="text-muted">Travesías en curso</h6>
                <h2>@Model.Resumen.TravesiasEnCurso</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-4 border-danger">
            <div class="card-body">
                <h6 class="text-muted">Órdenes abiertas</h6>
                <h2>@Model.Resumen.OrdenesAbiertas</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-4 border-dark">
            <div class="card-body">
                <h6 class="text-muted">Órdenes en progreso</h6>
                <h2>@Model.Resumen.OrdenesEnProgreso</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-4 border-warning">
            <div class="card-body">
                <h6 class="text-muted">Licencias por vencer</h6>
                <h2>@Model.Resumen.LicenciasPorVencer</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-start border-4 border-danger">
            <div class="card-body">
                <h6 class="text-muted">Licencias vencidas</h6>
                <h2>@Model.Resumen.LicenciasVencidas</h2>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-primary text-white">
                Licencias con alerta
            </div>
            <div class="card-body p-0">
                @if (Model.LicenciasAlertas.Any())
                {
                    <table class="table table-sm table-bordered mb-0">
                        <thead>
                            <tr>
                                <th>Persona</th>
                                <th>Licencia</th>
                                <th>Fecha</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.LicenciasAlertas)
                            {
                                <tr>
                                    <td>@item.NombreCompleto</td>
                                    <td>@item.NombreLicencia</td>
                                    <td>@item.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @if (item.Estado == "Vencida")
                                        {
                                            <span class="badge bg-danger">Vencida</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Por vencer</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-3">No hay licencias en alerta.</div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-dark text-white">
                Órdenes pendientes
            </div>
            <div class="card-body p-0">
                @if (Model.OrdenesPendientes.Any())
                {
                    <table class="table table-sm table-bordered mb-0">
                        <thead>
                            <tr>
                                <th>Código</th>
                                <th>Barco</th>
                                <th>Estado</th>
                                <th>Fecha límite</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrdenesPendientes)
                            {
                                <tr>
                                    <td>@item.CodigoOrden</td>
                                    <td>@item.NombreBarco</td>
                                    <td>@item.Estado</td>
                                    <td>@item.FechaLimite.ToString("dd/MM/yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-3">No hay órdenes pendientes.</div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-success text-white">
                Travesías activas
            </div>
            <div class="card-body p-0">
                @if (Model.TravesiasActivas.Any())
                {
                    <table class="table table-sm table-bordered mb-0">
                        <thead>
                            <tr>
                                <th>Barco</th>
                                <th>Ruta</th>
                                <th>Estado</th>
                                <th>Salida</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.TravesiasActivas)
                            {
                                <tr>
                                    <td>@item.NombreBarco</td>
                                    <td>@item.PuertoOrigen → @item.PuertoDestino</td>
                                    <td>@item.Estado</td>
                                    <td>@item.FechaPrevistaSalida.ToString("dd/MM/yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-3">No hay travesías activas.</div>
                }
            </div>
        </div>
    </div>
</div>