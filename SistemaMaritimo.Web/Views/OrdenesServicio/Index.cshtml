@model List<SistemaMaritimo.Web.Models.OrdenServicioListItemViewModel>

@{
    ViewData["Title"] = "Órdenes de Servicio";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Órdenes de Servicio</h2>
    <a asp-action="Create" class="btn btn-primary">Nueva orden</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Barco</label>
                <select name="barcoId" class="form-select" asp-items="ViewBag.Barcos">
                    <option value="">-- Todos --</option>
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Técnico</label>
                <select name="tecnicoId" class="form-select" asp-items="ViewBag.Tecnicos">
                    <option value="">-- Todos --</option>
                </select>
            </div>

            <div class="col-md-4 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-dark">Filtrar</button>
                <a asp-action="Index" class="btn btn-secondary">Limpiar</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-bordered table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Código</th>
                    <th>Barco</th>
                    <th>Tipo</th>
                    <th>Prioridad</th>
                    <th>Estado</th>
                    <th>Técnico</th>
                    <th>Fecha límite</th>
                    <th style="width:260px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CodigoOrden</td>
                            <td>@item.NombreBarco</td>
                            <td>@item.TipoMantenimiento</td>
                            <td>
                                @if (item.Prioridad == "Alta")
                                {
                                    <span class="badge bg-danger">Alta</span>
                                }
                                else if (item.Prioridad == "Media")
                                {
                                    <span class="badge bg-warning text-dark">Media</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Baja</span>
                                }
                            </td>
                            <td>@item.Estado</td>
                            <td>@(string.IsNullOrWhiteSpace(item.TecnicoAsignado) ? "-" : item.TecnicoAsignado)</td>
                            <td>@item.FechaLimite.ToString("dd/MM/yyyy")</td>
                            <td>
                                <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">Detalle</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                                <a asp-action="AsignarTecnico" asp-route-id="@item.Id" class="btn btn-secondary btn-sm">Asignar</a>
                                <a asp-action="CambiarEstado" asp-route-id="@item.Id" class="btn btn-dark btn-sm">Estado</a>
                                <a asp-action="Cerrar" asp-route-id="@item.Id" class="btn btn-success btn-sm">Cerrar</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center">No hay órdenes registradas.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>