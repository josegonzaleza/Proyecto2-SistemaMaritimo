@{
    ViewData["Title"] = "Cambiar Rol";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-warning">
                <h4 class="mb-0">Cambiar Rol de Usuario</h4>
            </div>
            <div class="card-body">
                <form asp-action="CambiarRol" method="post">
                    <input type="hidden" name="usuarioId" value="@ViewBag.UsuarioId" />

                    <div class="mb-3">
                        <label class="form-label">Seleccione el nuevo rol</label>
                        <select name="rolId" class="form-select" asp-items="ViewBag.Roles">
                            <option value="">-- Seleccione un rol --</option>
                        </select>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-warning">Guardar cambio</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>