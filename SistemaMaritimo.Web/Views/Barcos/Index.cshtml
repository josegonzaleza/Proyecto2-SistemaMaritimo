@model List<SistemaMaritimo.Web.Models.BarcoViewModel>

@{
    ViewData["Title"] = "Barcos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Flota y Activos</h2>
    <a asp-action="Create" class="btn btn-primary">Nuevo barco</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-bordered table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Matrícula</th>
                    <th>Puerto base</th>
                    <th>Capacidad</th>
                    <th>Motor</th>
                    <th>Estado</th>
                    <th style="width:220px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.NombreEmbarcacion</td>
                            <td>@item.MatriculaUnica</td>
                            <td>@item.PuertoBase</td>
                            <td>@item.CapacidadCarga</td>
                            <td>@item.ModeloMotor</td>
                            <td>
                                @if (!item.Archivado)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Archivado</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">Detalle</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>

                                @if (!item.Archivado)
                                {
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('¿Desea archivar este barco?');">
                                        Archivar
                                    </a>
                                }
                                else
                                {
                                    <a asp-action="Activar" asp-route-id="@item.Id" class="btn btn-success btn-sm">
                                        Activar
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center">No hay barcos registrados.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>