@model List<SistemaMaritimo.Web.Models.TravesiaListItemViewModel>

@{
    ViewData["Title"] = "Travesías";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Travesías</h2>
    <a asp-action="Create" class="btn btn-primary">Nueva travesía</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Barco</label>
                <select name="barcoId" class="form-select" asp-items="ViewBag.Barcos">
                    <option value="">-- Todos --</option>
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Puerto destino</label>
                <input type="text" name="puertoDestino" value="@ViewBag.PuertoDestino" class="form-control" />
            </div>

            <div class="col-md-4 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-dark">Filtrar</button>
                <a asp-action="Index" class="btn btn-secondary">Limpiar</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-bordered table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Barco</th>
                    <th>Origen</th>
                    <th>Destino</th>
                    <th>Salida</th>
                    <th>Llegada</th>
                    <th>Estado</th>
                    <th style="width:220px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.NombreBarco</td>
                            <td>@item.PuertoOrigen</td>
                            <td>@item.PuertoDestino</td>
                            <td>@item.FechaPrevistaSalida.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.FechaPrevistaLlegada.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (item.Estado == "Planeada")
                                {
                                    <span class="badge bg-primary">Planeada</span>
                                }
                                else if (item.Estado == "En Curso")
                                {
                                    <span class="badge bg-warning text-dark">En Curso</span>
                                }
                                else if (item.Estado == "Completada")
                                {
                                    <span class="badge bg-success">Completada</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">@item.Estado</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">Detalle</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                                <a asp-action="CambiarEstado" asp-route-id="@item.Id" class="btn btn-dark btn-sm">Estado</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center">No hay travesías registradas.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>